@model CinemaBooking2.ViewModels.ShowtimeVM
@{
    ViewData["Title"] = "Add Showtime";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow p-4">
            <h2 class="mb-4">🕐 Add New Showtime</h2>

            <form asp-action="CreateShowtime" method="post">
                <div class="mb-3">
                    <label asp-for="MovieId" class="form-label">Movie</label>
                    <select asp-for="MovieId" asp-items="ViewBag.Movies"
                            class="form-select bg-dark text-white border-secondary">
                        <option value="">-- Select Movie --</option>
                    </select>
                    <span asp-validation-for="MovieId" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="HallId" class="form-label">Hall</label>
                    <select asp-for="HallId" asp-items="ViewBag.Halls"
                            class="form-select bg-dark text-white border-secondary">
                        <option value="">-- Select Hall --</option>
                    </select>
                    <span asp-validation-for="HallId" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="StartTime" class="form-label">Date & Time</label>
                    <input asp-for="StartTime" type="datetime-local"
                           class="form-control bg-dark text-white border-secondary" />
                    <span asp-validation-for="StartTime" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Price" class="form-label">Ticket Price ($)</label>
                    <input asp-for="Price" type="number" step="0.01"
                           class="form-control bg-dark text-white border-secondary" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save Showtime</button>
                    <a asp-action="Showtimes" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}