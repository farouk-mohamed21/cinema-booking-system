@model IEnumerable<CinemaBooking2.Models.Showtime>
@{
    ViewData["Title"] = "Manage Showtimes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🕐 Manage Showtimes</h2>
    <a asp-action="CreateShowtime" class="btn btn-primary">+ Add Showtime</a>
</div>

<div class="table-responsive">
    <table class="table table-dark table-hover">
        <thead>
            <tr>
                <th>Movie</th>
                <th>Cinema</th>
                <th>Hall</th>
                <th>Date & Time</th>
                <th>Price</th>
                <th>Available Seats</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model.OrderBy(s => s.StartTime))
            {
                <tr>
                    <td>@s.Movie.Title</td>
                    <td>@s.Hall.Cinema.Name</td>
                    <td>@s.Hall.Name</td>
                    <td>@s.StartTime.ToString("dd MMM yyyy hh:mm tt")</td>
                    <td>$@s.Price</td>
                    <td>
                        <span class="badge @(s.AvailableSeats > 0 ? "bg-success" : "bg-danger")">
                            @s.AvailableSeats
                        </span>
                    </td>
                    <td>
                        <form asp-action="DeleteShowtime" method="post" class="d-inline"
                              onsubmit="return confirm('Delete this showtime?')">
                            <input type="hidden" name="id" value="@s.Id" />
                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>