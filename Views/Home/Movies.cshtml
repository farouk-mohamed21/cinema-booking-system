@model IEnumerable<CinemaBooking2.Models.Movie>
@{
    ViewData["Title"] = "Movies";
}

<h2 class="mb-4">🎥 All Movies</h2>

<div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
    @foreach (var movie in Model)
    {
        <div class="col">
            <div class="card h-100 shadow">
                @if (movie.PosterPath != null)
                {
                    <img src="@movie.PosterPath" class="card-img-top"
                         style="height:250px; object-fit:cover;" alt="@movie.Title" />
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center"
                         style="height:250px; background:#0f3460; font-size:4rem;">
                        🎬
                    </div>
                }
                <div class="card-body">
                    <h5 class="card-title">@movie.Title</h5>
                    <span class="badge bg-danger">@movie.Category.Name</span>
                    <p class="card-text mt-2 text-muted small">⏱ @movie.Duration min</p>
                    <p class="card-text small">@movie.Description</p>
                </div>
                <div class="card-footer">
                    <a asp-controller="Home" asp-action="MovieDetails"
                           asp-route-id="@movie.Id"
                           class="btn btn-primary w-100">
                        View Showtimes
                    </a>
                </div>
            </div>
        </div>
    }
</div>