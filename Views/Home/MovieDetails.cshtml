@model CinemaBooking2.Models.Movie
@{
    ViewData["Title"] = Model.Title;
}

<div class="row">
    <div class="col-md-4">
        @if (Model.PosterPath != null)
        {
            <img src="@Model.PosterPath" class="img-fluid rounded shadow" alt="@Model.Title" />
        }
        else
        {
            <div class="d-flex align-items-center justify-content-center rounded"
                 style="height:400px; background:#0f3460; font-size:6rem;">
                🎬
            </div>
        }
    </div>
    <div class="col-md-8">
        <h1>@Model.Title</h1>
        <span class="badge bg-danger fs-6">@Model.Category.Name</span>
        <p class="mt-3">⏱ Duration: @Model.Duration minutes</p>
        <p>@Model.Description</p>

        <h3 class="mt-4">🕐 Available Showtimes</h3>
        @if (!Model.Showtimes.Any())
        {
            <p class="text-muted">No showtimes available.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-dark table-hover">
                    <thead>
                        <tr>
                            <th>Cinema</th>
                            <th>Hall</th>
                            <th>Date & Time</th>
                            <th>Price</th>
                            <th>Seats</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model.Showtimes.OrderBy(s => s.StartTime))
                        {
                            <tr>
                                <td>@s.Hall.Cinema.Name</td>
                                <td>@s.Hall.Name</td>
                                <td>@s.StartTime.ToString("dd MMM yyyy hh:mm tt")</td>
                                <td>$@s.Price</td>
                                <td>
                                    <span class="badge @(s.AvailableSeats > 0 ? "bg-success" : "bg-danger")">
                                        @s.AvailableSeats seats
                                    </span>
                                </td>
                                <td>
                                    @if (!s.HasStarted && s.AvailableSeats > 0)
                                    {
                                        @if (User.Identity!.IsAuthenticated)
                                        {
                                            <a asp-controller="Booking" asp-action="Book"
                                               asp-route-showtimeId="@s.Id"
                                               class="btn btn-primary btn-sm">Book Now</a>
                                        }
                                        else
                                        {
                                            <a asp-controller="Account" asp-action="Login"
                                               class="btn btn-outline-light btn-sm">Login to Book</a>
                                        }
                                    }
                                    else if (s.HasStarted)
                                    {
                                        <span class="text-muted">Started</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger">Sold Out</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>